<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>UrduTools.Core</AssemblyName>
    <RootNamespace>UrduTools.Core</RootNamespace>
    <PackageId>UrduTools.Core</PackageId>
    <Version>1.1.0</Version>
    <Authors>Ahsan Mehmood</Authors>
    <Description>Comprehensive Urdu text processing library — normalization, analysis, search, numbers, tokenization, string utilities, sorting, and transliteration. Zero dependencies.</Description>
    <PackageTags>urdu;arabic;nlp;text;unicode;rtl;normalization</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/iamahsanmehmood/urdu-tools</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/iamahsanmehmood/urdu-tools</PackageProjectUrl>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>
  <ItemGroup>
    <None Include="../../../README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
