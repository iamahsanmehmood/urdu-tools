<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>UrduTools.Core</AssemblyName>
    <RootNamespace>UrduTools.Core</RootNamespace>
    <PackageId>UrduTools.Core</PackageId>
    <Version>1.0.0</Version>
    <Authors>UrduTools</Authors>
    <Description>Comprehensive Urdu text processing library — normalization, analysis, search, numbers, tokenization, string utilities, sorting, and transliteration.</Description>
    <PackageTags>urdu;arabic;nlp;text;unicode;rtl</PackageTags>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>
</Project>
